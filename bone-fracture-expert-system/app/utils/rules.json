{
  "validation_rules": {
    "fracture_probability_threshold": 0.5,
    "min_detection_confidence": 0.4,
    "anomalies": [
      {
        "code": "A001",
        "description": "High classification confidence but zero detections",
        "action": "trigger_manual_review"
      },
      {
        "code": "A002",
        "description": "Detection overlap or conflict with segmentation mask",
        "action": "warning"
      }
    ],
    "body_parts_supported": [
      "wrist",
      "hand",
      "arm",
      "shoulder",
      "leg",
      "foot",
      "pelvis",
      "chest"
    ]
  }
}
