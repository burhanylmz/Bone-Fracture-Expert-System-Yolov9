# LLM Sağlayıcı Seçimi (Opsiyonlar: ollama, vllm, openai)
LLM_PROVIDER=ollama

# Ollama Konfigürasyonu (Geliştirme Ortamı)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_NAME=llama3

# vLLM Konfigürasyonu (Sunum / Production Ortamı - 100 Doktor Yükü)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=casperhansen/llama-3-8b-instruct-awq

# Genel Ayarlar
LLM_TEMPERATURE=0.1
LLM_API_KEY=EMPTY